{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "eslint.config.js",
    "prettier.config.js",
    "vite.config.ts"
  ],
  "exclude": [
    "playground-ws-worker",
    "**/*.skip.test.ts"
  ],

  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"],
      "@archon/paths": ["./src/server/workflow-engine/stubs/paths.ts"],
      "@archon/git": ["./src/server/workflow-engine/stubs/git.ts"],
      "@archon/providers/types": ["./src/server/workflow-engine/stubs/providers-types.ts"],
      "@archon/providers": ["./src/server/workflow-engine/stubs/providers.ts"]
    }
  }
}
