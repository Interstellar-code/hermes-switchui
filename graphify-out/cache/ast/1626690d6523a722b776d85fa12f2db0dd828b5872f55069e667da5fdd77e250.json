true,\n      config: dashboard.available || legacyConfig,\n      jobs: dashboard.available || legacyJobs,\n      mcp,\n      mcpFallback,\n      conductor,\n      kanban,\n      dashboard,\n    }\n    lastProbeAt = Date.now()\n    logCapabilities(capabilities)\n    return capabilities\n  })", "is_member_call": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L759"}, {"caller_nid": "server_gateway_capabilities_ensuregatewayprobed", "callee": "now", "is_member_call": true, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L838"}]}