UT_MS),\n    })\n    if (!res.ok) {\n      throw new Error(`Dashboard index failed: ${res.status}`)\n    }\n    const html = await res.text()\n    const token = html.match(DASHBOARD_TOKEN_REGEX)?.[1]?.trim() || ''\n    if (!token) {\n      throw new Error('Dashboard session token not found in root HTML')\n    }\n    dashboardTokenCache = token\n    return token\n  })", "is_member_call": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L297"}, {"caller_nid": "server_gateway_capabilities_withdashboardbase", "callee": "test", "is_member_call": true, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L345"}, {"caller_nid": "server_gateway_capabilities_withdashboardbase", "callee": "startsWith", "is_member_call": true, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L346"}, {"caller_nid": "server_gateway_capabilities_dashboardfetch", "callee": "toUpperCase", "is_member_call": true, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L354"}, {"caller_nid": "server_gateway_capabilities_dashboardfetch", "callee": "doFetch", "is_member_call": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L381"}, {"caller_nid": "server_gateway_capabilities_dashboardfetch", "callee": "doFetch", "is_member_call": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L384"}, {"caller_nid": "server_gateway_capabilities_gatewayfetch", "callee": "test", "is_member_call": true, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/gateway-capabilities.ts", "source_location": "L399"}, {"caller_nid": "server_gateway_capabilities_gatewayfetch", "callee": "s