ll": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/claude-agent.ts", "source_location": "L98"}, {"caller_nid": "server_claude_agent_resolveclaudepython", "callee": "homedir", "is_member_call": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/claude-agent.ts", "source_location": "L98"}, {"caller_nid": "server_claude_agent_resolveclaudepython", "callee": "existsSync", "is_member_call": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/claude-agent.ts", "source_location": "L99"}, {"caller_nid": "server_claude_agent_isclaudeagenthealthy", "callee": "fetch", "is_member_call": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/claude-agent.ts", "source_location": "L107"}, {"caller_nid": "server_claude_agent_isclaudeagenthealthy", "callee": "timeout", "is_member_call": true, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/claude-agent.ts", "source_location": "L108"}, {"caller_nid": "server_claude_agent_startclaudeagent", "callee": "(async () => {\n    try {\n      const claudeEnv = readClaudeEnv()\n      const claudeBin = resolveClaudeBinary()\n      const agentDir = resolveClaudeAgentDir()\n\n      // Prefer the `hermes gateway run` binary path (the Nous installer's\n      // canonical entrypoint). Fall back to launching uvicorn against the\n      // source tree if we only have a directory.\n      let command: string\n      let commandArgs: Array<string>\n      let cwd: string | undefined\n\n      if (claudeBin) {\n        command = claudeBin\n        commandArgs = ['gateway', 'run']\n        cwd = agentDir ?? undefined\n      } else if (agentDir) {\n        command = resolveClaudePython(agentDir)\n        commandArgs = [\n          '-m',\n          'uvicorn',\n          'webapi.app:app',\n          '--host',\n          '0.0.0.0',\n          '--port',\n          String(CLAUDE_START_PORT),\n        ]\n        cwd = agentDir\n      } else {\n        return {\n          ok: false,\n          error:\n            \"hermes-agent not found. Run the installer: curl -fsSL https://hermes-workspace.com/install.sh | bash\",\n        }\n      }\n\n      const child = spawn(\n        command,\n        commandArgs,\n        {\n          cwd,\n          detached: true,\n          stdio: 'ignore',\n          env: {\n            ...process.env,\n            ...claudeEnv,\n            PATH: [\n              resolve(homedir(), '.claude', 'bin'),\n              resolve(homedir(), '.local', 'bin'),\n              agentDir ? resolve(agentDir, '.venv', 'bin') : '',\n              agentDir ? resolve(agentDir, 'venv', 'bin') : '',\n              process.env.PATH || '',\n            ].filter(Boolean).join(':'),\n          },\n        },\n      )\n\n      child.unref()\n\n      for (let attempt = 0; attempt < 10; attempt += 1) {\n        await new Promise((resolveAttempt) => setTimeout(resolveAttempt, 1_000))\n        if (await isClaudeAgentHealthy()) {\n          return {\n            ok: true,\n            pid: child.pid,\n            message: 'started',\n          }\n        }\n      }\n\n      return {\n        ok: true,\n        pid: child.pid,\n        message: 'starting',\n      }\n    } catch (error) {\n      return {\n        ok: false,\n        error: error instanceof Error ? error.message : String(error),\n      }\n    }\n  })", "is_member_call": false, "source_file": "/Volumes/Ext-nvme/Development/hermes-switchui/src/server/claude-agent.ts", "source_location": "L125"}]}